# Playwright auth / session state (contains login cookies — NEVER commit)
auth_state.json
*.auth.json
.auth/

# Persistent browser profile created by `login` (contains your Google session)
.nblm_profile/

# Extracted notebook data output
data/*.json
data/*.jsonl
!data/.gitkeep

# Python
__pycache__/
*.py[cod]
.venv/
venv/
.deps/
.env

# Logs / screenshots / traces
*.log
screenshots/
traces/
